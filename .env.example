# Gemini Developer API (AI Studio)
# Get an API key from AI Studio, then set one of:
# - GOOGLE_API_KEY (preferred)
# - GEMINI_API_KEY (also supported)
GOOGLE_API_KEY=your_api_key_here

# Shopify (drive_review app reads these — no sidebar prompts)
SHOPIFY_SHOP_DOMAIN=yourstore.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional if you already have a long-lived token:
# SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-01

# Drive review (optional overrides; defaults in drive_review/config.yaml)
# DRIVE_OUTPUTS_FOLDER_ID=
# DRIVE_XLSX_FILE_ID=
# FIRESTORE_PROJECT_ID=
