# Gemini Developer API (AI Studio)
# Get an API key from AI Studio, then set one of:
# - GOOGLE_API_KEY (preferred)
# - GEMINI_API_KEY (also supported)
GOOGLE_API_KEY=your_api_key_here
# Vision/text model for title autofill (must NOT be an image-generation model):
# TITLE_MODEL=models/gemini-3-flash-preview
# Image generation model for prompt1/prompt2 (must contain 'image'):
# IMAGE_MODEL=models/gemini-3.1-flash-image-preview

# Shopify (drive_review auto-connects from .env on every page load — all three required unless using ACCESS_TOKEN)
SHOPIFY_SHOP_DOMAIN=yourstore.myshopify.com
SHOPIFY_CLIENT_ID=your_dev_dashboard_client_id
SHOPIFY_CLIENT_SECRET=your_dev_dashboard_client_secret
# Optional if you already have a long-lived token:
# SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-01

# Drive review (optional overrides; defaults in drive_review/config.yaml)
# DRIVE_OUTPUTS_FOLDER_ID=
# Stock Google Sheet ID (default in drive_review/config.yaml):
# DRIVE_XLSX_FILE_ID=1TGAQxp446FbA-nPCeOgRmYiXiMjv_ywX
# FIRESTORE_PROJECT_ID=
